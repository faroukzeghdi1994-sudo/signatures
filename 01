<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>نظام التوقيعات - Signatures</title>
    <style>
        /* تنسيق الصفحة لتكون بملء الشاشة وبدون هوامش */
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            overflow: hidden; /* منع التمرير المزدوج */
            background-color: #f4f4f4;
        }

        /* تنسيق الإطار (Iframe) ليغطي الشاشة بالكامل */
        iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
</head>
<body>

    <iframe 
        src="https://script.google.com/macros/s/AKfycbwvYg2DqcpwzT_nKb2PuL7S93K-DqQdIp7sbHGd8b5CJ_SGA3ub_ebMmtn_qZo3lGJzkQ/exec" 
        allowfullscreen="true"
        allow="geolocation; microphone; camera">
    </iframe>

</body>
</html>
